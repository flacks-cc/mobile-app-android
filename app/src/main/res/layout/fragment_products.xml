            <!-- Código para mostrar los productos -->

            <!-- Primer producto -->
            <androidx.cardview.widget.CardView
                android:layout_width="166dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginRight="7.5dp"
