                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:onClick="cremaBarbaProduct"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Botón de favoritos -->
                    <ImageView
                        android:id="@+id/btnFavorite1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:contentDescription="@string/btnFavoProdu1"
                        android:src="@drawable/ic_favorite_vacio" />

                    <!-- Imagen -->
                    <ImageView
                        android:id="@+id/producto1"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center_horizontal"
                        android:contentDescription="@string/producto1"
                        android:src="@drawable/producto1" />

                    <!-- Texto de Marca -->
                    <TextView
                        android:id="@+id/marca1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center"
                        android:text="@string/imperial"
                        android:textColor="@color/golden_rod" />

                    <!-- Texto de descripción -->
                    <TextView
                        android:id="@+id/descrip1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center"
                        android:text="@string/cremaBarba"
                        android:textStyle="bold" />

                    <!-- Texto de precio -->
                    <TextView
                        android:id="@+id/precio1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center"
                        android:text="@string/cienPesos" />

